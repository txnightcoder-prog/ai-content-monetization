OPENAI_API_KEY=

# AI Image Generation — DALL·E 3 via OpenAI (thumbnails, social packs, avatars)
# Uses your existing OPENAI_API_KEY — no extra key needed.
# Cost: ~$0.04-0.08 per image. Already included in your OpenAI account.

# YouTube Data API v3 — for Parrot feature (fetch video metadata) and live trending
# Get free key at: https://console.cloud.google.com → APIs → YouTube Data API v3
YOUTUBE_DATA_API_KEY=

# ElevenLabs — AI voiceover / text-to-speech (https://elevenlabs.io)
# Free tier: 10,000 characters/month. Get key at elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=
# Optional: voice ID (default = Rachel, a clear neutral English voice)
# Browse voices at: elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=

# Pexels — free stock video clips for faceless videos (https://pexels.com/api)
# Completely free, unlimited requests. Get key at pexels.com/api
PEXELS_API_KEY=

# Local video output directory (where assembled MP4s are stored before YouTube upload)
VIDEO_OUTPUT_DIR=/tmp/videos

# Buffer — social media scheduling (https://buffer.com)
BUFFER_ACCESS_TOKEN=
BUFFER_INSTAGRAM_PROFILE_ID=
BUFFER_FACEBOOK_PROFILE_ID=
BUFFER_TIKTOK_PROFILE_ID=
BUFFER_YOUTUBE_PROFILE_ID=
BUFFER_TWITTER_PROFILE_ID=
BUFFER_LINKEDIN_PROFILE_ID=

# YouTube — direct upload (optional, Buffer can cover YouTube Shorts)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# TikTok — native Content Posting API v2 (real views/likes/comments/shares)
# Step 1: Create an app at https://developers.tiktok.com → My Apps
# Step 2: Add scopes: user.info.basic, video.list
# Step 3: Run the OAuth flow once to get your tokens
# Step 4: Paste them here — the backend auto-refreshes the access token on expiry
TIKTOK_CLIENT_KEY=           # "App Key" in TikTok developer portal
TIKTOK_CLIENT_SECRET=        # "App Secret" in TikTok developer portal
TIKTOK_ACCESS_TOKEN=         # Short-lived (24h) — auto-refreshed if refresh token is set
TIKTOK_REFRESH_TOKEN=        # Long-lived (365 days) — required for auto-refresh

# Other social tokens (used by legacy routes)
INSTAGRAM_ACCESS_TOKEN=

# Server ports
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Database (Azure PostgreSQL connection string)
DATABASE_URL=

# Azure — required for the Restart buttons in Diagnostics
# Create a service principal: az ad sp create-for-rbac --name "ai-content-restart" --role Contributor
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=0624b0c7-bc20-40a1-8156-b33b8f52e951
AZURE_RESOURCE_GROUP=ai-video-pipeline

# ── Gumroad → Personalised Video Pipeline ─────────────────────────────────

# Gumroad webhook HMAC secret (optional but recommended)
# Dashboard → Settings → Advanced → Webhooks → Copy the secret shown there
GUMROAD_WEBHOOK_SECRET=

# AWS S3 storage (optional — leave blank to keep videos local / use Azure)
AWS_S3_BUCKET=
AWS_REGION=us-east-1
# AWS credentials are read from ~/.aws/credentials or env vars below:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Azure Blob Storage for video output (reuses AZURE_STORAGE_CONNECTION_STRING from above)
AZURE_STORAGE_CONTAINER=personalised-videos

# Email delivery (SendGrid preferred, or Mailgun, or plain SMTP)
SENDGRID_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Sender identity shown on delivery emails
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Your Personalised Video
