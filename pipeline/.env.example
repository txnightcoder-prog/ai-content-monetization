# ── Required: OpenAI ──────────────────────────────────────────────────────────
# Get from: platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Required: JSON2Video ──────────────────────────────────────────────────────
# Sign up FREE at: https://json2video.com  (600 free credits to test)
# Hobby plan $16.95/mo = 50 videos | Professional $49.95/mo = 200 videos
# Get key: json2video.com/dashboard → API Key
JSON2VIDEO_API_KEY=your_json2video_api_key

# ── Required: Buffer ─────────────────────────────────────────────────────────
# Sign up at: https://buffer.com  (free = 3 channels)
# Create app at: https://buffer.com/developers/apps → copy Access Token
BUFFER_ACCESS_TOKEN=your_buffer_access_token

# Find your profile IDs by opening this URL in a browser (swap in your token):
# https://api.bufferapp.com/1/profiles.json?access_token=YOUR_TOKEN
# Copy the "id" value for each platform you want to post to — comma-separated
BUFFER_PROFILE_IDS=profile_id_tiktok,profile_id_instagram,profile_id_youtube

# ── Content Settings ─────────────────────────────────────────────────────────
# Your content niche — the more specific the better
# Examples: "personal finance tips", "fitness for beginners", "AI tools", "crypto news"
NICHE=AI tools and productivity

# How many videos to generate per day (Hobby plan: max 50/mo so keep at 5)
VIDEOS_PER_DAY=5

# ── Video Settings (optional — defaults are fine to start) ───────────────────
# Voice for the AI voiceover — Azure Neural voices work best
# More voices: https://json2video.com/docs/v2/#voices
VOICE=en-US-JennyNeural

# Background music style: happy | sad | epic | calm | none
MUSIC=happy
